# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
trim_trailing_whitespace = true
insert_final_newline = true

[*.css]
indent_size = 4
indent_style = space

[*.{md,mdx}]
trim_trailing_whitespace = false

[*.{ps1,psm1}]
indent_size = 4
indent_style = tab

[*.sh,*.bash,*.zsh]
indent_size = 2
indent_style = space

[*.{json,yaml,yml,toml}]
indent_size = 2
